Algoritmo DiasDeLa_Semana
	Definir dia Como Entero
	
	//Solicitar al usuario
	Escribir Sin Saltar "Dame un numero entero del 1 al 7"
	Leer dia 
	
	Segun variable_numerica Hacer
		1:
			Escribir "Lunes"
		2:
			Escribir "Martes"
		3:
			Escribir "Miercoles"
		4:
			Escribir "Jueves"
		5:
			Escribir "Viernes"
		6:
			Escribir "S·bado"
		7:
			Escribir "Domingo"
		De Otro Modo:
			Escribir "Digite un valor entre el 1 y 7"
	Fin Segun
FinAlgoritmo
